<?xml version="1.0" encoding="utf-8"?>
<!--
  OutOfProcess: uses shared "dotnet" runtime (works well on MonsterASP when .NET 10 stack is selected).
  InProcess can fail if the worker cannot load the app host the same way as your dev machine.
  After deploy, check /logs for stdout_*.log if the app still fails.
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet"
                  arguments=".\HeartCathAPI.dll"
                  stdoutLogEnabled="true"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="outofprocess" />
    </system.webServer>
  </location>
</configuration>
