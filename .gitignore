## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
## See https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017 cache/options directory
.vs/
# Uncomment if you have tasks that create the project's static files in wwwroot
#wwwroot/

# Compiled Content (Windows)
*.nbc
*.nbi
*.res
*.resources
*.obj
*.lib
*.exp
*.pch
*.pdb
*.idb
*.ilk
*.exe
*.dll
*.sys
*.bin

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
# Uncomment if using NuGet Repository Config
# [Nn]u[Gg]et.config
# [Nn]u[Gg]et.exe

# Entity Framework Core distributed cached model
*.efdef

# Large binary folders
wwwroot/analysis/
wwwroot/dicom/
wwwroot/uploads/
wwwroot/videos/
temp/
